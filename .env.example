OUTPUT_DIR=output/runs
TIMEZONE=Asia/Shanghai

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
# 主 LLM 模型名；当 LLM_USE_MIRA_AS_LLM=true 时，Mira 也会读取这个值作为 model
LLM_MODEL=gpt-4.1-mini
LLM_USE_COCO_AS_LLM=false
LLM_USE_MIRA_AS_LLM=false
LLM_TIMEOUT_SECONDS=6000
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1600

# ---- Mira ----
MIRA_API_BASE_URL=
# 可选：浏览器态完整 Cookie，适用于直接复用 https://mira.bytedance.com 的登录态
MIRA_COOKIE=
# Mira Web 的 `mira_session` 值；会被发送为 `Cookie: mira_session=...`
MIRA_JWT_TOKEN=
# Mira 请求头中的客户端版本标识，便于后端排查问题
MIRA_CLIENT_VERSION=autochecklist/0.1.0
# 是否使用 Mira 替代原有 Coco Task1/Task2 代码分析链路
MIRA_USE_FOR_CODE_ANALYSIS=false

# ---- Coco Agent ----
# 当 LLM_USE_COCO_AS_LLM=true 时，会使用下面的 COCO_API_BASE_URL 作为主 LLM 请求地址
# 示例: https://codebase-api.byted.org/v2
# Coco API Base URL（供主 LLM / MR 分析 / Coco 工具链复用）
COCO_API_BASE_URL=https://codebase-api.byted.org/v2
# 必填：Coco 鉴权 token
COCO_JWT_TOKEN=
# Coco agent 名称，OpenAPI 仅支持 sandbox / copilot
COCO_AGENT_NAME=sandbox
# 可选：显式指定 Coco 模型名
COCO_MODEL_NAME=
# 单个 Coco task 最大等待秒数
COCO_TASK_TIMEOUT=120
# 轮询起始间隔（秒）
COCO_POLL_INTERVAL_START=2.0
# 轮询最大间隔（秒）
COCO_POLL_INTERVAL_MAX=10.0

# ---- 知识检索 (GraphRAG / LightRAG) ----
# 是否启用知识检索功能（默认关闭）
ENABLE_KNOWLEDGE_RETRIEVAL=false
# LightRAG 索引数据工作目录
KNOWLEDGE_WORKING_DIR=./knowledge_db
# 知识文档（Markdown）存放目录
KNOWLEDGE_DOCS_DIR=./knowledge_docs
# 检索模式: naive / local / global / hybrid
KNOWLEDGE_RETRIEVAL_MODE=hybrid
# 检索返回的最大结果数
KNOWLEDGE_TOP_K=10
# Embedding 模型（留空则复用 LLM_MODEL）
KNOWLEDGE_EMBEDDING_MODEL=
# 单个知识文档最大 KB 数
KNOWLEDGE_MAX_DOC_SIZE_KB=1024
