LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=6000
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1600

# ---- LLM 重试与降级配置 ----
# 最大重试次数（0 = 禁用重试）
LLM_MAX_RETRIES=3
# 初始退避时间（秒）
LLM_RETRY_BASE_DELAY=1.0
# 最大退避时间（秒）
LLM_RETRY_MAX_DELAY=60.0
# Fallback 模型名称（空 = 不启用降级）
LLM_FALLBACK_MODEL=
# Fallback API Base URL（空 = 复用主模型 URL）
LLM_FALLBACK_BASE_URL=
# Fallback API Key（空 = 复用主模型 Key）
LLM_FALLBACK_API_KEY=

# ---- 知识检索 (GraphRAG / LightRAG) ----
# 是否启用知识检索功能（默认关闭）
ENABLE_KNOWLEDGE_RETRIEVAL=false
# LightRAG 索引数据工作目录
KNOWLEDGE_WORKING_DIR=./knowledge_db
# 知识文档（Markdown）存放目录
KNOWLEDGE_DOCS_DIR=./knowledge_docs
# 检索模式: naive / local / global / hybrid
KNOWLEDGE_RETRIEVAL_MODE=hybrid
# 检索返回的最大结果数
KNOWLEDGE_TOP_K=10
# Embedding 模型（留空则复用 LLM_MODEL）
KNOWLEDGE_EMBEDDING_MODEL=
# 单个知识文档最大 KB 数
KNOWLEDGE_MAX_DOC_SIZE_KB=1024
