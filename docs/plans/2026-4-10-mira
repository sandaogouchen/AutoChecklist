class MiraError(Exception):
    """Mira API 基础异常。"""
    def __init__(self, message: str, code: int = -1, log_id: str = ""):
        super().__init__(message)
        self.code = code
        self.log_id = log_id

class MiraAuthError(MiraError):
    """认证失败（401）。"""

class MiraAPIError(MiraError):
    """API 业务错误（code != 0）。"""

class MiraTimeoutError(MiraError):
    """请求或 SSE 流超时。"""

class MiraSSEError(MiraError):
    """SSE 连接或解析异常。"""

class MiraUploadError(MiraError):
    """文件上传失败。"""

class MiraUnavailableError(MiraError):
