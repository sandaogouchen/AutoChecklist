class PromptLoader:
    """提示词文件加载器。

    按约定优于配置的方式，从 prompts/ 目录中加载提示词文件。
    支持 {variable} 占位符替换和 _shared/ 目录下的共享片段引用。
    """

    def __init__(self, prompts_dir: str = "prompts"):
        self._base_dir = Path(prompts_dir)
        self._cache: dict[str, str] = {}

    def load(self, node_name: str, prompt_name: str, **variables) -> str:
        """加载并渲染提示词。

        查找路径：prompts/{node_name}/{prompt_name}.md
        若不存在则返回空字符串（向后兼容——代码中仍保留 fallback 常量）。

        Args:
            node_name: 节点名称（如 "context_research"）
            prompt_name: 提示词名称（如 "lead_researcher_system"）
            **variables: 占位符变量

        Returns:
            渲染后的提示词文本
        """
        cache_key = f"{node_name}/{prompt_name}"
        if cache_key not in self._cache:
            path = self._base_dir / node_name / f"{prompt_name}.md"
            if path.exists():
                self._cache[cache_key] = path.read_text(encoding="utf-8")
            else:
                self._cache[cache_key] = ""
        template = self._cache[cache_key]
        if not template:
            return ""
        # 处理 _shared 引用：{{include:_shared/json_constraint.md}}
        template = self._resolve_includes(template)
        # 变量替换：{mr_title} → actual value
        return template.format_map(defaultdict(str, **variables))

    def _resolve_includes(self, template: str) -> str:
        """解析 {{include:path}} 指令。"""
        pattern = re.compile(r"\{\{include:([^}]+)\}\}")
        def replacer(match):
            include_path = self._base_dir / match.group(1).strip()
            if include_path.exists():
                return include_path.read_text(encoding="utf-8")
            return ""
        return pattern.sub(replacer, template)
