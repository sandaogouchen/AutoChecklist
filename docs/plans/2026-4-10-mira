async def _send_message_async(self, session_id, content, config=None):
    """通过 SSE 发送消息并收集完整响应。"""
    url = f"{self._config.base_url}/mira/api/v1/chat/completion"
    body = {
        "sessionId": session_id,
        "content": content,
        "messageType": 1,                    # Text
        "summaryAgent": self._config.model or "",
        "dataSources": [],
        "comprehensive": 0,
    }
    if config:
        body["config"] = config              # tool_list, model, mode 等

    chunks = []
    async with httpx.AsyncClient(timeout=self._timeout) as client:
        async with client.stream("POST", url, json=body, headers=self._headers) as resp:
            resp.raise_for_status()
            async for line in resp.aiter_lines():
                if not line.startswith("data:"):
                    continue
                payload = json.loads(line[5:].strip())
                # 根据 SSE event 类型累积内容
                chunks.append(payload)

    return self._assemble_response(chunks)

def send_message_sync(self, session_id, content, config=None):
    """同步包装，复用现有 _run_sync 桥接模式。"""
    return _run_sync(self._send_message_async(session_id, content, config))
